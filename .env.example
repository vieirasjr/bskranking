# ── Mercado Pago ─────────────────────────────────────────────
# Access token do MP (backend apenas — NUNCA exponha no frontend)
MP_ACCESS_TOKEN="APP_USR-xxxx"
MP_TEST_PAYER_EMAIL=""   # Email do usuário comprador de teste (sandbox apenas)
VITE_MP_PUBLIC_KEY="APP_USR-xxxx"   # Public key (frontend) — obtida no painel MP > Credenciais

# URL base da aplicação (para back_url do checkout)
APP_BASE_URL="https://seudominio.vercel.app"
